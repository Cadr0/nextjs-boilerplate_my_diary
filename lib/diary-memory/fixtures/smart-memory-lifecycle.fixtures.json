{
  "transitionScenarios": [
    {
      "name": "desire_to_completed_with_possession_successor",
      "existing": { "type": "desire", "status": "active", "subject": "лонгборд" },
      "message": "я купил лонгборд",
      "expected": { "action": "mark_completed", "status": "completed", "successorType": "possession" }
    },
    {
      "name": "issue_to_resolved",
      "existing": { "type": "issue", "status": "active", "subject": "спина" },
      "message": "спина уже прошла",
      "expected": { "action": "mark_completed", "status": "completed" }
    },
    {
      "name": "plan_to_abandoned",
      "existing": { "type": "plan", "status": "active", "subject": "переезд" },
      "message": "передумал переезжать",
      "expected": { "action": "mark_abandoned", "status": "abandoned" }
    },
    {
      "name": "goal_progress_enrich",
      "existing": { "type": "goal", "status": "active", "subject": "начать бегать" },
      "message": "уже третью неделю бегаю",
      "expected": { "action": "enrich_existing", "status": "monitoring" }
    }
  ],
  "signalDetectionScenarios": [
    { "name": "detect_kupil", "message": "купил лонгборд", "expectedSignal": "purchase_completed" },
