    { "name": "detect_peredumal", "message": "передумал переезжать", "expectedSignal": "abandoned" },
    { "name": "detect_bolshe_ne_hochu", "message": "больше не хочу покупать", "expectedSignal": "no_longer_wanted" },
    { "name": "detect_zakonchil", "message": "закончил проект", "expectedSignal": "finished" },
    { "name": "detect_proshlo", "message": "боль в спине прошла", "expectedSignal": "issue_gone" },
    { "name": "detect_reshil_problemu", "message": "решил проблему со сном", "expectedSignal": "issue_resolved" }
  ],
  "signalSafetyScenarios": [
    {
      "name": "no_subject_should_not_close_unrelated",
      "existing": { "type": "desire", "status": "active", "subject": "лонгборд" },
      "message": "передумал",
      "expected": { "action": "keep_as_is_or_enrich" }
